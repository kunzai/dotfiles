# Identity
set realname = "Sven Kuncikowski-Michaelis"
set from = "kuncikowski@gmail.com"

# IMAP inbox
set imap_user = "kuncikowski@gmail.com"
set folder = "imaps://imap.gmail.com/"
set spoolfile = "+INBOX"
set postponed = "+[Gmail]/Drafts"
set record = "+[Gmail]/Sent Mail"
set trash = "+[Gmail]/Trash"
set imap_pass = "`secret-tool lookup service imap user kuncikowski@gmail.com`"

# Common IMAP folders
set postponed = "+Drafts"
set record    = "+Sent"
set trash     = "+Trash"

# SMTP sending
set smtp_url  = "smtps://kuncikowski@gmail.com@smtp.example.com:465/"
# set smtp_pass = "secret"   # or leave unset to be prompted

# Editor for composing messages
set editor = "nvim"

# Basic behaviour
set sort         = threads        # thread messages by conversation
set sort_aux     = reverse-last-date-received
set mark_old     = no             # don't mark new messages as old on exit
set mime_forward = ask-yes        # ask whether to forward as attachment

# Headers to hide in the pager
ignore *
unignore from: to: cc: date: subject:
hdr_order from: to: cc: date: subject:
